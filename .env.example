# SunPath Solar — environment
# Copy this file to .env.local and add at least one key.

# Primary model key — Google AI Studio, FREE tier, no credit card required.
# Get one at https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-studio-key

# (Recommended) Groq key — FREE at https://console.groq.com
# Enables automatic failover when the primary provider is throttled or down,
# and lets the conversion-lift eval run entirely on free quota.
# GROQ_API_KEY=gsk_...

# (Optional) Claude — the strongest demo model. Then set SUNPATH_PROVIDER=anthropic.
# ANTHROPIC_API_KEY=sk-ant-...

# --- Model selection (all optional; defaults live in lib/model.ts) ---
# SUNPATH_PROVIDER=google | anthropic | groq
# SUNPATH_MODEL=gemini-flash-latest
# SUNPATH_FAILOVER=0        # disable the automatic Groq failover
