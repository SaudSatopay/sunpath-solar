# SunPath Solar — environment

# Google AI Studio API key — FREE tier, no credit card required.
# Get one at https://aistudio.google.com/apikey
# The agent runs on Gemini 2.5 Flash. Copy this file to .env.local and paste your key.
GOOGLE_GENERATIVE_AI_API_KEY=your-google-ai-studio-key

# (Optional) To run on Claude instead: set ANTHROPIC_API_KEY here and change the model line in
# app/api/chat/route.ts to anthropic("claude-opus-4-8") (and eval/run.ts to use @ai-sdk/anthropic).
# ANTHROPIC_API_KEY=sk-ant-...
